@page "/users"
@model NovelManangment.Pages.Users.IndexModel
@using NovelManangment.Models
@{
    ViewData["Title"] = "Manage Users";
    var roleMeta = new Dictionary<UserRole, (string label, string css, string icon)>
    {
        [UserRole.Member] = ("Member", "text-bg-secondary", "fa-user"),
        [UserRole.Publisher] = ("Publisher", "text-bg-info", "fa-pen-nib"),
        [UserRole.Admin] = ("Admin", "text-bg-danger", "fa-shield-alt"),
        [UserRole.Moderator] = ("Moderator", "text-bg-warning", "fa - brands fa - mastodon"),
    };
}

<div class="app-content-header">
    <div class="container-fluid">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h3 class="mb-0">
                    <i class="fas fa-users text-primary me-2"></i>Manage Users
                </h3>
                <small class="text-muted">@Model.TotalCount result(s)</small>
            </div>
            <a href="/users/create" class="btn btn-primary btn-sm">
                <i class="fas fa-user-plus me-1"></i> Add User
            </a>
        </div>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">

        @if (TempData["Success"] is string ok)
        {
            <div class="alert alert-success alert-dismissible d-flex align-items-center gap-2 mb-3">
                <i class="fas fa-check-circle"></i><span>@ok</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] is string err)
        {
            <div class="alert alert-danger alert-dismissible d-flex align-items-center gap-2 mb-3">
                <i class="fas fa-exclamation-circle"></i><span>@err</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Stats -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="fs-4 fw-bold text-primary">@Model.ActiveCount</div>
                    <div class="text-muted small">Active</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="fs-4 fw-bold text-info">@Model.PublisherCount</div>
                    <div class="text-muted small">Publishers</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="fs-4 fw-bold text-danger">@Model.DeletedCount</div>
                    <div class="text-muted small">Deactivated</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="fs-4 fw-bold text-success">
                        @(Model.ActiveCount + Model.DeletedCount)
                    </div>
                    <div class="text-muted small">Total</div>
                </div>
            </div>
        </div>

        <!-- Filter -->
        <form method="get" class="card border-0 shadow-sm mb-4">
            <div class="card-body py-2">
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <div class="input-group input-group-sm" style="max-width:260px;">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" name="search" value="@Model.Search"
                               class="form-control" placeholder="Name, username, email..." />
                    </div>
                    <div class="d-flex gap-1">
                        @foreach (var (val, lbl) in new[] {
              ("","All"),("User","Users"),("Publisher","Publishers"),("Admin","Admins")})
                        {
                            <button type="submit" name="role-filter" value="@val"
                                    class="btn btn-sm @((Model.RoleFilter ?? "") == val
                                                                                   ? "btn-primary" : "btn-outline-secondary")">
                                @lbl
                            </button>
                        }
                    </div>
                    <div class="form-check form-switch mb-0 ms-1">
                        <input class="form-check-input" type="checkbox" name="show-deleted"
                               value="true" id="showDeleted"
                        @(Model.ShowDeleted ? "checked" : "")
                               onchange="this.form.submit()" />
                        <label class="form-check-label small" for="showDeleted">
                            Show deactivated
                        </label>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.RoleFilter))
                    {
                        <a href="/users" class="btn btn-sm btn-link text-muted">
                            <i class="fas fa-times me-1"></i>Clear
                        </a>
                    }
                </div>
            </div>
        </form>

        <!-- Table -->
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:13px;">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">User</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th class="text-center">Novels</th>
                            <th>Joined</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Users.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="fas fa-users fa-2x d-block mb-2 opacity-50"></i>
                                    No users found.
                                </td>
                            </tr>
                        }
                        @foreach (var user in Model.Users)
                        {
                            <tr class="@(user.IsDeleted ? "opacity-50" : "")">
                                <td class="ps-3">
                                    <div class="d-flex align-items-center gap-2">
                                        @if (!string.IsNullOrEmpty(user.AvatarUrl))
                                        {
                                            <img src="@user.AvatarUrl"
                                                 style="width:36px;height:36px;border-radius:50%;
                                            object-fit:cover;flex-shrink:0;" />
                                        }
                                        else
                                        {
                                            <div style="width:36px;height:36px;border-radius:50%;flex-shrink:0;
                                                background:linear-gradient(135deg,#667eea,#764ba2);
                                                display:flex;align-items:center;justify-content:center;
                                                color:#fff;font-weight:700;font-size:14px;">
                                                @user.DisplayName[0]
                                            </div>
                                        }
                                        <div>
                                            <div class="fw-semibold">
                                                @user.DisplayName
                                                @if (user.IsDeleted)
                                                {
                                                    <span class="badge text-bg-danger ms-1"
                                                          style="font-size:9px;">Deactivated</span>
                                                }
                                            </div>
                                            <div class="text-muted" style="font-size:11px;">
                                                @@@user.UserName
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-muted">@user.Email</td>
                                <td>
                                    <span class="badge @roleMeta[user.Role].css" style="font-size:11px;">
                                        <i class="fas @roleMeta[user.Role].icon me-1"></i>
                                        @roleMeta[user.Role].label
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @(user.NovelCount > 0
                                                                                      ? "text-bg-primary" : "text-bg-light border text-muted")">
                                        @user.NovelCount
                                    </span>
                                </td>
                                <td class="text-muted" style="font-size:11px;">
                                    @user.CreatedAt.ToString("dd MMM yyyy")
                                </td>
                                <td class="text-end pe-3">
                                    <div class="d-flex gap-1 justify-content-end">
                                        <a href="/users/@user.Id"
                                               class="btn btn-xs btn-outline-secondary" title="View detail">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="/users/@user.Id/edit"
                                               class="btn btn-xs btn-outline-primary" title="Edit">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        @if (user.IsDeleted)
                                        {
                                            <form method="post" asp-page-handler="Restore" class="d-inline">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button type="submit" class="btn btn-xs btn-outline-success"
                                                        title="Restore">
                                                    <i class="fas fa-undo"></i>
                                                </button>
                                            </form>
                                            <button class="btn btn-xs btn-outline-danger"
                                                    onclick="confirmHardDelete(@user.Id,
                                                '@Html.Raw(user.DisplayName.Replace("'", "\\'"))',
                                                @user.NovelCount)"
                                                    title="Permanently delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-xs btn-outline-danger"
                                                    onclick="confirmDeactivate(@user.Id,
                                                '@Html.Raw(user.DisplayName.Replace("'", "\\'"))')"
                                                    title="Deactivate">
                                                <i class="fas fa-user-slash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (Model.TotalPages > 1)
            {
                <div class="card-footer bg-white">
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.PageNumber ? "active" : "")">
                                <a class="page-link"
                                       href="?search=@Model.Search&role-filter=@Model.RoleFilter&show-deleted=@Model.ShowDeleted&page-number=@p">
                                    @p
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </div>
</div>

<!-- Deactivate modal -->
<div class="modal fade" id="modalDeactivate" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <form method="post" asp-page-handler="Delete">
                <input type="hidden" name="userId" id="deact_id" />
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title text-danger">
                        <i class="fas fa-user-slash me-2"></i>Deactivate User
                    </h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body pt-1">
                    <p class="small mb-1">Deactivate:</p>
                    <p class="fw-semibold mb-1" id="deact_name"></p>
                    <p class="text-muted small mb-0">
                        <i class="fas fa-info-circle me-1"></i>Can be restored later.
                    </p>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-sm btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-sm btn-danger">Deactivate</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Hard delete modal -->
<div class="modal fade" id="modalHardDelete" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <form method="post" asp-page-handler="HardDelete">
                <input type="hidden" name="userId" id="hd_id" />
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title text-danger">
                        <i class="fas fa-skull me-2"></i>Permanently Delete
                    </h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body pt-1">
                    <p class="small mb-1">Permanently delete:</p>
                    <p class="fw-semibold mb-2" id="hd_name"></p>
                    <div class="alert alert-danger py-2 mb-0" style="font-size:12px;">
                        <i class="fas fa-exclamation-triangle me-1"></i>
                        <strong>Irreversible.</strong> All data will be lost.
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-sm btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-sm btn-danger">Delete Forever</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .btn-xs { padding: 2px 7px; font-size: 11px; border-radius: 3px; }
</style>

@section Scripts {
    <script>
        function confirmDeactivate(id, name) {
            document.getElementById('deact_id').value          = id;
            document.getElementById('deact_name').textContent  = name;
            new bootstrap.Modal(document.getElementById('modalDeactivate')).show();
        }
        function confirmHardDelete(id, name, novelCount) {
            if (novelCount > 0) {
                alert(`Cannot delete "${name}" — they own ${novelCount} novel(s). Remove novels first.`);
                return;
            }
            document.getElementById('hd_id').value          = id;
            document.getElementById('hd_name').textContent  = name;
            new bootstrap.Modal(document.getElementById('modalHardDelete')).show();
        }
    </script>
}