@page "/users/{userId:int}/edit"
@model NovelManangment.Pages.Users.EditModel
@using NovelManangment.Models
@{
    ViewData["Title"] = $"Edit — {Model.User.DisplayName}";
}

<div class="app-content-header">
  <div class="container-fluid">
    <div class="d-flex align-items-center justify-content-between">
      <div>
        <h3 class="mb-0">
          <i class="fas fa-user-edit text-warning me-2"></i>Edit User
        </h3>
        <small class="text-muted">@@{Model.User.UserName}</small>
      </div>
      <div class="d-flex gap-2">
        <a href="/users/@Model.User.Id"
           class="btn btn-sm btn-outline-secondary">
          <i class="fas fa-eye me-1"></i> Detail
        </a>
        <a href="/users/@Model.User.Id"
                class="btn btn-sm btn-outline-secondary"
                onclick="if (history.length > 1) { history.back(); return false; }">
            <i class="fas fa-arrow-left me-1"></i> Back
        </a>
      </div>
    </div>
  </div>
</div>

<div class="app-content">
  <div class="container-fluid">
    <div class="row justify-content-center">
      <div class="col-lg-7">
        <form method="post">
          <input type="hidden" asp-for="Input.UserId" />

          <!-- Profile -->
          <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white border-bottom py-2">
              <h6 class="mb-0 fw-semibold">
                <i class="fas fa-id-card me-1 text-primary"></i> Profile
              </h6>
            </div>
            <div class="card-body">
              <div class="row g-3">

                <!-- Avatar preview -->
                <div class="col-12 d-flex align-items-center gap-3 mb-1">
                  <div id="avatarWrap">
                    @if (!string.IsNullOrEmpty(Model.User.AvatarUrl))
                    {
                      <img id="avatarPreview" src="@Model.User.AvatarUrl"
                           style="width:60px;height:60px;border-radius:50%;
                                  object-fit:cover;border:2px solid #dee2e6;" />
                    }
                    else
                    {
                      <div id="avatarFallback"
                           style="width:60px;height:60px;border-radius:50%;
                                  background:linear-gradient(135deg,#667eea,#764ba2);
                                  display:flex;align-items:center;justify-content:center;
                                  color:#fff;font-weight:700;font-size:22px;">
                        @Model.User.DisplayName[0]
                      </div>
                    }
                  </div>
                  <div>
                    <div class="fw-semibold">@Model.User.DisplayName</div>
                    <div class="text-muted small">@@@Model.User.UserName</div>
                    <div class="text-muted small">
                      Joined @Model.User.CreatedAt.ToString("dd MMM yyyy")
                    </div>
                  </div>
                </div>

                <div class="col-md-6">
                  <label asp-for="Input.DisplayName" class="form-label fw-semibold">
                    Display Name <span class="text-danger">*</span>
                  </label>
                  <input asp-for="Input.DisplayName" class="form-control" />
                  <span asp-validation-for="Input.DisplayName"
                        class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                  <label asp-for="Input.Email" class="form-label fw-semibold">
                    Email <span class="text-danger">*</span>
                  </label>
                  <input asp-for="Input.Email" type="email" class="form-control" />
                  <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                <div class="col-12">
                  <label asp-for="Input.AvatarUrl" class="form-label fw-semibold">
                    Avatar URL
                    <span class="text-muted fw-normal">(optional)</span>
                  </label>
                  <input asp-for="Input.AvatarUrl" class="form-control"
                         placeholder="https://..."
                         oninput="previewAvatar(this.value)" />
                  <span asp-validation-for="Input.AvatarUrl" class="text-danger small"></span>
                </div>
              </div>
            </div>
          </div>

          @if (Model.CanChangeRole)
          {
          <!-- Role -->
              <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white border-bottom py-2">
                  <h6 class="mb-0 fw-semibold">
                    <i class="fas fa-shield-alt me-1 text-danger"></i> Role
                  </h6>
                </div>
                <div class="card-body">
                  <div class="row g-3">
                    @foreach (var role in Enum.GetValues<UserRole>())
                    {
                      var (icon, desc, css) = role switch {
                        UserRole.Member      => ("fa-user",      "Read novels and comment.", "secondary"),
                        UserRole.Publisher => ("fa-pen-nib",   "Publish and manage novels.", "info"),
                        UserRole.Admin     => ("fa-shield-alt","Full admin access.", "danger"),
                        _                  => ("fa-user",      "", "secondary")
                      };
                      <div class="col-md-4">
                        <div class="form-check card border p-3 h-100 role-card">
                          <input class="form-check-input" type="radio"
                                 name="Input.Role" value="@(role)"
                                 id="role_@role" onchange="highlightRole()"
                                 @(Model.Input.Role == role ? "checked" : "") />
                          <label class="form-check-label w-100" for="role_@role"
                                 style="cursor:pointer;">
                            <div class="fw-semibold">
                              <i class="fas @icon text-@css me-1"></i> @role
                            </div>
                            <div class="text-muted" style="font-size:11px;margin-top:4px;">
                              @desc
                            </div>
                          </label>
                        </div>
                      </div>
                    }
                  </div>
                </div>
              </div>
          }
          <!-- Reset password (optional) -->
          <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-bottom py-2">
              <h6 class="mb-0 fw-semibold">
                <i class="fas fa-key me-1 text-warning"></i> Reset Password
                <span class="text-muted fw-normal small">(leave blank to keep current)</span>
              </h6>
            </div>
            <div class="card-body">
              <div class="row g-3">
                <div class="col-md-6">
                  <label asp-for="Input.NewPassword" class="form-label fw-semibold">
                    New Password
                  </label>
                  <div class="input-group">
                    <input asp-for="Input.NewPassword" type="password" id="npwd"
                           class="form-control" placeholder="Min 6 characters" />
                    <button type="button" class="btn btn-outline-secondary"
                            onclick="togglePwd('npwd',this)">
                      <i class="fas fa-eye"></i>
                    </button>
                  </div>
                  <span asp-validation-for="Input.NewPassword"
                        class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                  <label asp-for="Input.ConfirmNewPassword" class="form-label fw-semibold">
                    Confirm New Password
                  </label>
                  <div class="input-group">
                    <input asp-for="Input.ConfirmNewPassword" type="password" id="cnpwd"
                           class="form-control" placeholder="Repeat new password" />
                    <button type="button" class="btn btn-outline-secondary"
                            onclick="togglePwd('cnpwd',this)">
                      <i class="fas fa-eye"></i>
                    </button>
                  </div>
                  <span asp-validation-for="Input.ConfirmNewPassword"
                        class="text-danger small"></span>
                </div>
              </div>
            </div>
          </div>

          <div class="d-flex justify-content-between">
            <a href="@(User.IsInRole("Admin") ? "/users" : "/")" class="btn btn-outline-secondary">
              <i class="fas fa-times me-1"></i> Cancel
            </a>
            <button type="submit" class="btn btn-warning px-4">
              <i class="fas fa-save me-1"></i> Save Changes
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
function togglePwd(id, btn) {
    const el = document.getElementById(id);
    const isText = el.type === 'text';
    el.type = isText ? 'password' : 'text';
    btn.innerHTML = `<i class="fas fa-eye${isText ? '' : '-slash'}"></i>`;
}

function previewAvatar(url) {
    const wrap = document.getElementById('avatarWrap');
    if (!url?.trim()) return;
    wrap.innerHTML = `<img src="${url}"
        style="width:60px;height:60px;border-radius:50%;
               object-fit:cover;border:2px solid #dee2e6;"
        onerror="this.style.display='none'" />`;
}

function highlightRole() {
    document.querySelectorAll('.role-card').forEach(c =>
        c.classList.remove('border-primary'));
    const checked = document.querySelector('input[name="Input.Role"]:checked');
    if (checked) checked.closest('.role-card').classList.add('border-primary');
}
highlightRole();
</script>
}