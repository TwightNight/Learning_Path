@page "/users/{userId}"
@model NovelManangment.Pages.Users.DetailModel
@using NovelManangment.Models
@{
    ViewData["Title"] = $"User — {Model.User.DisplayName}";
    var user = Model.User;

    var roleMeta = new Dictionary<UserRole, (string label, string css, string icon)>
    {
        [UserRole.Member] = ("Member", "text-bg-secondary", "fa-user"),
        [UserRole.Publisher] = ("Publisher", "text-bg-info", "fa-pen-nib"),
        [UserRole.Admin] = ("Admin", "text-bg-danger", "fa-shield-alt"),
        [UserRole.Moderator] = ("Moderator", "text-bg-warning", "fa - brands fa - mastodon"),

    };
    var statusMeta = new Dictionary<NovelStatus, (string label, string css)>
    {
        [NovelStatus.Ongoing] = ("Ongoing", "text-bg-success"),
        [NovelStatus.Completed] = ("Completed", "text-bg-primary"),
        [NovelStatus.Hiatus] = ("Hiatus", "text-bg-warning"),
        [NovelStatus.Dropped] = ("Dropped", "text-bg-danger"),
    };
    var typeMeta = new Dictionary<NovelType, (string label, string css)>
    {
        [NovelType.Original] = ("Original", "text-bg-info"),
        [NovelType.Raw] = ("Raw", "text-bg-secondary"),
        [NovelType.MachineTranslated] = ("MT", "text-bg-warning"),
        [NovelType.HumanTranslated] = ("HT", "text-bg-primary"),
        [NovelType.Parody] = ("Parody", "text-bg-dark"),
    };
}

<div class="app-content-header">
    <div class="container-fluid">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h3 class="mb-0">
                    <i class="fas fa-user-circle text-primary me-2"></i>User Detail
                </h3>
                <small class="text-muted">@@@user.UserName</small>
            </div>
            <div class="d-flex gap-2">
                <a href="/users/@user.Id/edit"
                       class="btn btn-sm btn-warning">
                    <i class="fas fa-pen me-1"></i> Edit
                </a>
                <a href="@(User.IsInRole("Admin") ? "/users" : "/")" class="btn btn-sm btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Back
                </a>
            </div>
        </div>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">
        <div class="row g-4">

            <!-- ── LEFT: Profile card ── -->
            <div class="col-lg-4">

                <!-- Profile -->
                <div class="card border-0 shadow-sm mb-3 text-center">
                    <div class="card-body py-4">
                        @if (!string.IsNullOrEmpty(user.AvatarUrl))
                        {
                            <img src="@user.AvatarUrl"
                                 style="width:90px;height:90px;border-radius:50%;
                            object-fit:cover;border:3px solid #dee2e6;" />
                        }
                        else
                        {
                            <div style="width:90px;height:90px;border-radius:50%;margin:0 auto;
                                background:linear-gradient(135deg,#667eea,#764ba2);
                                display:flex;align-items:center;justify-content:center;
                                color:#fff;font-weight:700;font-size:32px;">
                                @user.DisplayName[0]
                            </div>
                        }
                        <h5 class="mt-3 mb-1 fw-bold">@user.DisplayName</h5>
                        <div class="text-muted mb-2">@@@user.UserName</div>
                        <span class="badge @roleMeta[user.Role].css">
                            <i class="fas @roleMeta[user.Role].icon me-1"></i>
                            @roleMeta[user.Role].label
                        </span>
                        @if (user.IsDeleted)
                        {
                            <span class="badge text-bg-danger ms-1">Deactivated</span>
                        }
                    </div>
                </div>

                <!-- Info -->
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-header bg-white border-bottom py-2">
                        <h6 class="mb-0 fw-semibold">
                            <i class="fas fa-info-circle me-1 text-muted"></i> Info
                        </h6>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-borderless mb-0"
                               style="font-size:13px;">
                            <tr>
                                <td class="text-muted ps-3" style="width:40%;">Email</td>
                                <td class="fw-medium">@user.Email</td>
                            </tr>
                            <tr>
                                <td class="text-muted ps-3">Joined</td>
                                <td>@user.CreatedAt.ToString("dd MMM yyyy")</td>
                            </tr>
                            <tr>
                                <td class="text-muted ps-3">Last updated</td>
                                <td>
                                    @(user.LastUpdatedAt.HasValue
                                        ? user.LastUpdatedAt.Value.ToString("dd MMM yyyy")
                                        : "—")
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted ps-3">Status</td>
                                <td>
                                    @if (user.IsDeleted)
                                    {
                                        <span class="badge text-bg-danger">Deactivated</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-success">Active</span>
                                    }
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Stats -->
                <div class="row g-2">
                    <div class="col-4">
                        <div class="card border-0 shadow-sm text-center py-2">
                            <div class="fw-bold text-primary fs-5">@Model.Novels.Count</div>
                            <div class="text-muted" style="font-size:11px;">Novels</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="card border-0 shadow-sm text-center py-2">
                            <div class="fw-bold text-success fs-5">@Model.TotalChapters</div>
                            <div class="text-muted" style="font-size:11px;">Chapters</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="card border-0 shadow-sm text-center py-2">
                            <div class="fw-bold text-warning fs-5">
                                @(Model.TotalViews >= 1000
                                    ? $"{Model.TotalViews / 1000.0:F1}K"
                                    : Model.TotalViews.ToString())
                            </div>
                            <div class="text-muted" style="font-size:11px;">Views</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── RIGHT: Novels ── -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom d-flex
                        align-items-center justify-content-between py-2">
                        <h6 class="mb-0 fw-semibold">
                            <i class="fas fa-book me-1 text-primary"></i>
                            Published Novels
                            <span class="badge text-bg-secondary ms-1">@Model.Novels.Count</span>
                        </h6>
                    </div>

                    @if (!Model.Novels.Any())
                    {
                        <div class="card-body text-center text-muted py-5">
                            <i class="fas fa-book fa-2x d-block mb-2 opacity-50"></i>
                            No novels published yet.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0"
                                   style="font-size:13px;">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-3">Cover</th>
                                        <th>Title</th>
                                        <th>Type</th>
                                        <th>Status</th>
                                        <th>Published</th>
                                        <th class="pe-3 text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var novel in Model.Novels)
                                    {
                                        <tr>
                                            <td class="ps-3">
                                                @if (!string.IsNullOrEmpty(novel.CoverUrl))
                                                {
                                                    <img src="@novel.CoverUrl"
                                                         style="width:28px;height:40px;object-fit:cover;
                                                    border-radius:3px;" />
                                                }
                                                else
                                                {
                                                    <div style="width:28px;height:40px;background:#e9ecef;
                                                        border-radius:3px;display:flex;align-items:center;
                                                        justify-content:center;">
                                                        <i class="fas fa-book text-muted"
                                                           style="font-size:10px;"></i>
                                                    </div>
                                                }
                                            </td>
                                            <td>
                                                <a href="/novels/@novel.Slug" target="_blank"
                                                       class="text-decoration-none fw-semibold text-reset">
                                                    @(novel.Title.Length > 35
                                                        ? novel.Title[..35] + "…" : novel.Title)
                                                </a>
                                            </td>
                                            <td>
                                                <span class="badge @typeMeta[novel.Type].css"
                                                      style="font-size:10px;">
                                                    @typeMeta[novel.Type].label
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge @statusMeta[novel.Status].css"
                                                      style="font-size:10px;">
                                                    @statusMeta[novel.Status].label
                                                </span>
                                            </td>
                                            <td class="text-muted">
                                                @Model.GetTimeAgo(novel.CreatedAt)
                                            </td>
                                            <td class="text-end pe-3">
                                                <div class="d-flex gap-1 justify-content-end">
                                                    <a href="/novels/@novel.Slug" target="_blank"
                                                           class="btn btn-xs btn-outline-secondary"
                                                           title="View">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a href="/novels/@novel.Id/manage"
                                                           class="btn btn-xs btn-outline-success"
                                                           title="Manage content">
                                                        <i class="fas fa-layer-group"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .btn-xs {
        padding: 2px 7px;
        font-size: 11px;
        border-radius: 3px;
    }
</style>