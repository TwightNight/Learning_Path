@page "/genres"
@model NovelManangment.Pages.Genres.IndexModel
@{
    ViewData["Title"] = "Manage Genres";
}

<div class="app-content-header">
    <div class="container-fluid">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h3 class="mb-0">
                    <i class="fas fa-tags text-success me-2"></i>Genres
                </h3>
                <small class="text-muted">@Model.TotalCount genre(s) total</small>
            </div>
        </div>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">

        @if (TempData["Success"] is string ok)
        {
            <div class="alert alert-success alert-dismissible d-flex align-items-center gap-2 mb-3">
                <i class="fas fa-check-circle"></i><span>@ok</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] is string err)
        {
            <div class="alert alert-danger alert-dismissible d-flex align-items-center gap-2 mb-3">
                <i class="fas fa-exclamation-circle"></i><span>@err</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row g-4">

            <!-- ── LEFT: Quick create form ── -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm sticky-top" style="top:72px;">
                    <div class="card-header bg-white border-bottom py-2">
                        <h6 class="mb-0 fw-semibold">
                            <i class="fas fa-plus-circle me-1 text-success"></i> Add New Genre
                        </h6>
                    </div>
                    <div class="card-body">
                        <form method="post" asp-page-handler="Create">
                            <input type="hidden" asp-for="PageNumber" />
                            <input type="hidden" asp-for="Search" />
                            <div class="mb-3">
                                <label asp-for="Input.Name" class="form-label fw-semibold">
                                    Name <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Input.Name" class="form-control"
                                       placeholder="e.g. Fantasy, Action..."
                                       oninput="previewSlug(this.value)" />
                                <span asp-validation-for="Input.Name" class="text-danger small"></span>
                                <div class="mt-1" style="font-size:11px;color:#aaa;">
                                    Slug: <code id="slugPreview">—</code>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Input.Description" class="form-label fw-semibold">
                                    Description
                                    <span class="text-muted fw-normal">(optional)</span>
                                </label>
                                <textarea asp-for="Input.Description" class="form-control" rows="3"
                                          placeholder="Brief description..."></textarea>
                                <span asp-validation-for="Input.Description" class="text-danger small"></span>
                            </div>
                            <button type="submit" class="btn btn-success w-100">
                                <i class="fas fa-plus me-1"></i> Create Genre
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- ── RIGHT: Genre table ── -->
            <div class="col-lg-8">

                <!-- Search bar -->
                <form method="get" class="mb-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" name="Search" value="@Model.Search"
                               class="form-control" placeholder="Search genres..." />
                        <button type="submit" class="btn btn-primary">Search</button>
                        @if (!string.IsNullOrEmpty(Model.Search))
                        {
                            <a href="/genres" class="btn btn-outline-secondary">
                                <i class="fas fa-times"></i>
                            </a>
                        }
                    </div>
                </form>

                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" style="font-size:13px;">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3" style="width:36px;">#</th>
                                    <th>Name</th>
                                    <th>Slug</th>
                                    <th>Description</th>
                                    <th class="text-center">Novels</th>
                                    <th class="text-end pe-3">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Genres.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            <i class="fas fa-tags fa-2x d-block mb-2 opacity-50"></i>
                                            No genres found.
                                        </td>
                                    </tr>
                                }
                                @foreach (var (genre, idx) in Model.Genres.Select((g, i) => (g, i)))
                                {
                                    <tr>
                                        <td class="ps-3 text-muted">
                                            @((Model.PageNumber - 1) * 15 + idx + 1)
                                        </td>
                                        <td class="fw-semibold">@genre.Name</td>
                                        <td>
                                            <code class="text-muted" style="font-size:11px;">@genre.Slug</code>
                                        </td>
                                        <td class="text-muted">
                                            @if (!string.IsNullOrEmpty(genre.Description))
                                            {
                                                <span title="@genre.Description">
                                                    @(genre.Description.Length > 40
                                                        ? genre.Description[..40] + "…"
                                                        : genre.Description)
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="fst-italic opacity-50">—</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <span class="badge @(genre.NovelCount > 0 ? "text-bg-primary" : "text-bg-light border text-muted")">
                                                @genre.NovelCount
                                            </span>
                                        </td>
                                        <td class="text-end pe-3">
                                            <div class="d-flex gap-1 justify-content-end">
                                                <a href="/genres/@genre.Id/edit"
                                                       class="btn btn-xs btn-outline-primary" title="Edit">
                                                    <i class="fas fa-pen"></i>
                                                </a>
                                                <button class="btn btn-xs btn-outline-danger" title="Delete"
                                                    @(genre.NovelCount > 0 ? "disabled" : "")
                                                        onclick="confirmDelete(@genre.Id, '@Html.Raw(genre.Name.Replace("'", "\\'"))', @genre.NovelCount)">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    @if (Model.TotalPages > 1)
                    {
                        <div class="card-footer bg-white border-top">
                            <ul class="pagination pagination-sm justify-content-center mb-0">
                                @for (int p = 1; p <= Model.TotalPages; p++)
                                {
                                    <li class="page-item @(p == Model.PageNumber ? "active" : "")">
                                        <a class="page-link"
                                           href="?search=@Model.Search&page-number=@p">@p</a>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Delete confirm modal -->
<div class="modal fade" id="modalDelete" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <form method="post" asp-page-handler="Delete">
                <input type="hidden" name="genreId" id="del_id" />
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title text-danger">
                        <i class="fas fa-trash me-2"></i>Delete Genre
                    </h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body pt-2">
                    <p class="small mb-1">Delete genre:</p>
                    <p class="fw-semibold" id="del_name"></p>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-sm btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewSlug(val) {
            const slug = val.toLowerCase().trim()
                .replace(/[^a-z0-9\s-]/g, '')
                .replace(/\s+/g, '-')
                .replace(/^-+|-+$/g, '');
            document.getElementById('slugPreview').textContent = slug || '—';
        }

        function confirmDelete(id, name, novelCount) {
            if (novelCount > 0) return;
            document.getElementById('del_id').value          = id;
            document.getElementById('del_name').textContent  = name;
            new bootstrap.Modal(document.getElementById('modalDelete')).show();
        }
    </script>
}