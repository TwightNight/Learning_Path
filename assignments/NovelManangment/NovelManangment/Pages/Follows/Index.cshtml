@page "/my-follows"
@model NovelManangment.Pages.Follows.IndexModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@using NovelManangment.Models
@{
    ViewData["Title"] = "My Follows";
}

<div class="app-content">
    <div class="container-fluid">

        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h4 class="fw-bold mb-1">
                    <i class="fas fa-heart text-danger me-2"></i>My Follows
                </h4>
                <span class="text-muted" style="font-size:13px;">
                    @Model.TotalCount novel@(Model.TotalCount != 1 ? "s" : "") followed
                </span>
            </div>
        </div>

        @if (!Model.Follows.Any())
        {
            <!-- Empty state -->
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-5">
                    <i class="fas fa-heart fa-3x text-muted mb-3" style="opacity:.3;"></i>
                    <h5 class="fw-semibold mb-2">No follows yet</h5>
                    <p class="text-muted mb-4" style="font-size:14px;">
                        Start following novels to keep track of them here.
                    </p>
                    <a href="/novels" class="btn btn-primary px-4">
                        <i class="fas fa-book me-2"></i>Browse Novels
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3" id="followList">
                @foreach (var item in Model.Follows)
                {
                    var statusBadge = item.Status switch
                    {
                        NovelStatus.Ongoing => ("Ongoing", "text-bg-success"),
                        NovelStatus.Completed => ("Completed", "text-bg-primary"),
                        NovelStatus.Hiatus => ("Hiatus", "text-bg-warning"),
                        NovelStatus.Dropped => ("Dropped", "text-bg-danger"),
                        _ => ("Unknown", "text-bg-secondary")
                    };

                    <div class="card border-0 shadow-sm follow-item" id="follow-@item.Slug">
                        <div class="card-body p-3">
                            <div class="d-flex gap-3">

                                <!-- Cover -->
                                <a href="/novels/@item.Slug" class="flex-shrink-0">
                                    @if (!string.IsNullOrEmpty(item.CoverUrl))
                                    {
                                        <img src="@item.CoverUrl" alt="@item.Title"
                                             style="width:72px;height:100px;object-fit:cover;
                                        border-radius:6px;box-shadow:0 2px 8px rgba(0,0,0,.15);" />
                                    }
                                    else
                                    {
                                        <div style="width:72px;height:100px;background:#e9ecef;border-radius:6px;
                                            display:flex;align-items:center;justify-content:center;">
                                            <i class="fas fa-book text-muted"></i>
                                        </div>
                                    }
                                </a>

                                <!-- Info -->
                                <div class="flex-grow-1" style="min-width:0;">
                                    <div class="d-flex align-items-start justify-content-between gap-2">
                                        <div>
                                            <a href="/novels/@item.Slug"
                                                   class="text-decoration-none text-reset fw-bold"
                                                   style="font-size:15px;line-height:1.3;">
                                                @item.Title
                                            </a>
                                            <div class="text-muted mt-1" style="font-size:13px;">
                                                @item.AuthorName
                                            </div>
                                        </div>
                                        <button class="btn btn-link p-0 text-danger flex-shrink-0"
                                                onclick="unfollowNovel('@item.Slug')"
                                                title="Unfollow" style="font-size:18px;">
                                            <i class="fas fa-heart"></i>
                                        </button>
                                    </div>

                                    <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
                                        <span class="badge @statusBadge.Item2" style="font-size:11px;">
                                            @statusBadge.Item1
                                        </span>
                                        <span class="text-muted" style="font-size:12px;">
                                            <i class="fas fa-list me-1"></i>@item.ChapterCount chapters
                                        </span>
                                        <span class="text-muted" style="font-size:12px;">
                                            <i class="fas fa-clock me-1"></i>
                                            Updated @GetTimeAgo(item.LastUpdatedAt ?? item.FollowedAt)
                                        </span>
                                    </div>

                                    <div class="text-muted mt-1" style="font-size:11px;">
                                        <i class="fas fa-heart me-1 text-danger"></i>
                                        Followed @item.FollowedAt.ToString("dd MMM yyyy")
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</div>

<input type="hidden" name="__RequestVerificationToken"
       value="@Antiforgery.GetAndStoreTokens(HttpContext).RequestToken" />

@functions {
    string GetTimeAgo(DateTime dt)
    {
        var s = DateTime.Now - dt;
        if (s.Days > 365) return $"{s.Days / 365}y ago";
        if (s.Days > 30) return $"{s.Days / 30}mo ago";
        if (s.Days > 0) return $"{s.Days}d ago";
        if (s.Hours > 0) return $"{s.Hours}h ago";
        if (s.Minutes > 0) return $"{s.Minutes}m ago";
        return "Just now";
    }
}

@section Scripts {
    <script>
        async function unfollowNovel(slug) {
            if (!confirm('Unfollow this novel?')) return;

            try {
                const res  = await fetch(`/my-follows?handler=Unfollow&slug=${slug}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken':
                            document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
                    }
                });
                const data = await res.json();
                if (data.error) { alert(data.error); return; }

                // Xóa card khỏi DOM
                const card = document.getElementById('follow-' + slug);
                card.style.transition = 'opacity .3s, transform .3s';
                card.style.opacity    = '0';
                card.style.transform  = 'translateX(20px)';
                setTimeout(() => {
                    card.remove();

                    // Cập nhật count
                    const list  = document.getElementById('followList');
                    const count = list?.querySelectorAll('.follow-item').length ?? 0;

                    document.querySelector('.text-muted[style*="font-size:13px"]').textContent =
                        `${count} novel${count !== 1 ? 's' : ''} followed`;

                    // Hiện empty state nếu hết
                    if (count === 0) {
                        list.innerHTML = `
                            <div class="card border-0 shadow-sm">
                                <div class="card-body text-center py-5">
                                    <i class="fas fa-heart fa-3x text-muted mb-3" style="opacity:.3;"></i>
                                    <h5 class="fw-semibold mb-2">No follows yet</h5>
                                    <p class="text-muted mb-4" style="font-size:14px;">
                                        Start following novels to keep track of them here.
                                    </p>
                                    <a href="/novels" class="btn btn-primary px-4">
                                        <i class="fas fa-book me-2"></i>Browse Novels
                                    </a>
                                </div>
                            </div>`;
                    }
                }, 300);

            } catch {
                alert('Something went wrong. Please try again.');
            }
        }
    </script>
}