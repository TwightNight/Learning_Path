@page "/my-novels"
@model NovelManangment.Pages.Novels.MyNovelsModel
@using NovelManangment.Models
@{
    ViewData["Title"] = "My Novels";

    var statusMeta = new Dictionary<NovelStatus, (string label, string css, string icon)>
    {
        [NovelStatus.Ongoing]   = ("Ongoing",   "text-bg-success", "fa-circle-play"),
        [NovelStatus.Completed] = ("Completed", "text-bg-primary", "fa-circle-check"),
        [NovelStatus.Hiatus]    = ("Hiatus",    "text-bg-warning", "fa-circle-pause"),
        [NovelStatus.Dropped]   = ("Dropped",   "text-bg-danger",  "fa-circle-xmark"),
    };

    var typeMeta = new Dictionary<NovelType, (string label, string css)>
    {
        [NovelType.Original]          = ("Original", "text-bg-info"),
        [NovelType.Raw]               = ("Raw",      "text-bg-secondary"),
        [NovelType.MachineTranslated] = ("MT",       "text-bg-warning"),
        [NovelType.HumanTranslated]   = ("HT",       "text-bg-primary"),
        [NovelType.Parody]            = ("Parody",   "text-bg-dark"),
    };

    var publishMeta = new Dictionary<PublishStatus, (string label, string css, string icon)>
    {
        [PublishStatus.Draft]    = ("Draft",    "text-bg-secondary", "fa-file"),
        [PublishStatus.Pending]  = ("Pending",  "text-bg-warning",   "fa-clock"),
        [PublishStatus.Approved] = ("Approved", "text-bg-success",   "fa-check-circle"),
        [PublishStatus.Rejected] = ("Rejected", "text-bg-danger",    "fa-times-circle"),
    };
}

<div class="app-content-header">
    <div class="container-fluid">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h3 class="mb-0"><i class="fas fa-book-open text-primary me-2"></i>My Novels</h3>
                <small class="text-muted">@Model.TotalCount novel(s) published</small>
            </div>
            <a href="/novels/create" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i> New Novel
            </a>
        </div>
    </div>
</div>

<div class="app-content">
  <div class="container-fluid">

    <!-- ── Summary cards ── -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
          <div class="fs-3 fw-bold text-primary">@Model.TotalCount</div>
          <div class="text-muted small">Total Novels</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
          <div class="fs-3 fw-bold text-success">
            @Model.Novels.Sum(n => n.TotalChapters)
          </div>
          <div class="text-muted small">Total Chapters</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
          <div class="fs-3 fw-bold text-warning">
            @Model.Novels.Sum(n => n.TotalViews).ToString("N0")
          </div>
          <div class="text-muted small">Total Views</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
          <div class="fs-3 fw-bold text-info">
            @Model.Novels.Count(n => n.Status == NovelStatus.Ongoing)
          </div>
          <div class="text-muted small">Ongoing</div>
        </div>
      </div>
    </div>

    <!-- ── Filter bar ── -->
    <form method="get" class="card border-0 shadow-sm mb-4">
      <div class="card-body py-2">
        <div class="d-flex flex-wrap gap-2 align-items-center">
          <div class="input-group input-group-sm" style="max-width:280px;">
            <span class="input-group-text"><i class="fas fa-search"></i></span>
            <input type="text" name="search" value="@Model.Search"
                   class="form-control" placeholder="Search title..." />
          </div>

          <div class="d-flex gap-1 flex-wrap">
            @{
                var statuses = new[] {
                    ("", "All"),
                    ("Ongoing", "Ongoing"),
                    ("Completed", "Completed"),
                    ("Hiatus", "Hiatus"),
                    ("Dropped", "Dropped")
                };
            }
            @foreach (var (val, lbl) in statuses)
            {
                var active = (Model.StatusFilter ?? "") == val;
                <button type="submit" name="status" value="@val"
                        class="btn btn-sm @(active ? "btn-primary" : "btn-outline-secondary")">
                    @lbl
                </button>
            }
          </div>

          @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.StatusFilter))
          {
            <a href="/my-novels" class="btn btn-sm btn-link text-muted">
              <i class="fas fa-times me-1"></i>Clear
            </a>
          }
        </div>
      </div>
    </form>

    <!-- ── Novel list ── -->
    @if (!Model.Novels.Any())
    {
      <div class="text-center py-5 text-muted">
        <i class="fas fa-book fa-3x mb-3 d-block opacity-50"></i>
        @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.StatusFilter))
        {
          <p>No novels match your filter.</p>
          <a href="/my-novels" class="btn btn-sm btn-outline-primary">Clear filters</a>
        }
        else
        {
          <p>You haven't published any novels yet.</p>
          <a href="/novels/create" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i> Create your first novel
          </a>
        }
      </div>
    }
    else
    {
      <div class="d-flex flex-column gap-3">
        @foreach (var novel in Model.Novels)
        {
          <div class="card border-0 shadow-sm novel-row @(novel.IsDeleted ? "opacity-50 border-warning border" : "")">

            <!-- Deactivated banner -->
            @if (novel.IsDeleted)
            {
              <div class="card-header bg-warning bg-opacity-10 border-0 py-1 px-3"
                   style="font-size:12px;color:#856404;">
                <i class="fas fa-ban me-1"></i>
                Deactivated — hidden from readers
                @if (novel.DeletedAt.HasValue)
                {
                  <span class="ms-2 text-muted">since @novel.DeletedAt.Value.ToString("dd MMM yyyy")</span>
                }
              </div>
            }

            <div class="card-body p-3">
              <div class="d-flex gap-3">

                <!-- Cover -->
                <a href="/novels/@novel.Slug" target="_blank" class="flex-shrink-0">
                  @if (!string.IsNullOrEmpty(novel.CoverUrl))
                  {
                    <img src="@novel.CoverUrl" alt="@novel.Title"
                         style="width:64px;height:90px;object-fit:cover;border-radius:6px;
                                box-shadow:0 2px 8px rgba(0,0,0,.15);" />
                  }
                  else
                  {
                    <div style="width:64px;height:90px;background:#e9ecef;border-radius:6px;
                                display:flex;align-items:center;justify-content:center;">
                      <i class="fas fa-book text-muted"></i>
                    </div>
                  }
                </a>

                <!-- Info -->
                <div class="flex-grow-1 min-w-0">
                  <div class="d-flex align-items-start justify-content-between gap-2 flex-wrap">
                    <div>
                      <h6 class="mb-1 fw-semibold">
                        <a href="/novels/@novel.Slug" target="_blank"
                           class="text-decoration-none text-reset">
                          @novel.Title
                        </a>
                      </h6>

                      <!-- Badges: Type + Status + PublishStatus -->
                      <div class="d-flex gap-1 flex-wrap mb-2">
                        <span class="badge @typeMeta[novel.Type].css" style="font-size:10px;">
                          @typeMeta[novel.Type].label
                        </span>
                        <span class="badge @statusMeta[novel.Status].css" style="font-size:10px;">
                          <i class="fas @statusMeta[novel.Status].icon me-1"></i>
                          @statusMeta[novel.Status].label
                        </span>
                        <span class="badge @publishMeta[novel.PublishStatus].css" style="font-size:10px;">
                          <i class="fas @publishMeta[novel.PublishStatus].icon me-1"></i>
                          @publishMeta[novel.PublishStatus].label
                        </span>
                      </div>
                    </div>

                    <!-- Action buttons -->
                    <div class="d-flex gap-2 flex-shrink-0 flex-wrap">
                      @if (!novel.IsDeleted)
                      {
                        <a href="/novels/@novel.Slug" target="_blank"
                           class="btn btn-sm btn-outline-secondary" title="View public page">
                          <i class="fas fa-eye"></i>
                        </a>
                        <a href="/novels/edit/@novel.Id"
                           class="btn btn-sm btn-outline-primary" title="Edit novel info">
                          <i class="fas fa-pen"></i>
                        </a>
                        <a href="/novels/@novel.Id/manage"
                           class="btn btn-sm btn-outline-success" title="Manage volumes & chapters">
                          <i class="fas fa-layer-group"></i>
                        </a>
                      }

                      <!-- Deactivate / Restore -->
                      <form method="post" asp-page-handler="ToggleDelete" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="novelId" value="@novel.Id" />
                        <button type="submit"
                                class="btn btn-sm @(novel.IsDeleted ? "btn-outline-success" : "btn-outline-warning")"
                                title="@(novel.IsDeleted ? "Restore" : "Deactivate")"
                                onclick="return confirm('@(novel.IsDeleted ? "Restore this novel?" : "Deactivate this novel? It will be hidden from readers.")')">
                          <i class="fas @(novel.IsDeleted ? "fa-rotate-left" : "fa-ban")"></i>
                        </button>
                      </form>

                      @if (!novel.IsDeleted)
                      {
                        <button class="btn btn-sm btn-outline-danger" title="Delete novel"
                                onclick="confirmDelete(@novel.Id, '@Html.Raw(novel.Title.Replace("'", "\\'"))')">
                          <i class="fas fa-trash"></i>
                        </button>
                      }
                    </div>
                  </div>

                  <!-- Stats row -->
                  <div class="d-flex gap-3 flex-wrap mb-2" style="font-size:12px;color:#888;">
                    <span title="Volumes">
                      <i class="fas fa-book-open me-1"></i>@novel.TotalVolumes vol
                    </span>
                    <span title="Chapters">
                      <i class="fas fa-list-ol me-1"></i>@novel.TotalChapters ch
                    </span>
                    <span title="Total views">
                      <i class="fas fa-eye me-1"></i>@novel.TotalViews.ToString("N0")
                    </span>
                    <span title="Created">
                      <i class="fas fa-calendar-plus me-1"></i>@novel.CreatedAt.ToString("dd MMM yyyy")
                    </span>
                    @if (novel.LastUpdatedAt.HasValue)
                    {
                      <span title="Last updated" class="text-success">
                        <i class="fas fa-clock me-1"></i>@novel.LastUpdatedAt.Value.ToString("dd MMM yyyy")
                      </span>
                    }
                  </div>

                  <!-- PublishStatus notification box -->
                  @if (novel.PublishStatus == PublishStatus.Draft)
                  {
                    <div class="alert alert-secondary py-1 px-2 mb-0 d-flex align-items-center gap-2"
                         style="font-size:12px;">
                      <i class="fas fa-file"></i>
                      <span>Draft — not submitted for review yet.</span>
                      <form method="post" asp-page-handler="Submit" class="ms-auto d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="novelId" value="@novel.Id" />
                        <button type="submit" class="btn btn-xs btn-primary">
                          <i class="fas fa-paper-plane me-1"></i> Submit for Review
                        </button>
                      </form>
                    </div>
                  }
                  else if (novel.PublishStatus == PublishStatus.Pending)
                  {
                    <div class="alert alert-warning py-1 px-2 mb-0 d-flex align-items-center gap-2"
                         style="font-size:12px;">
                      <i class="fas fa-clock"></i>
                      <span>Waiting for moderator review...</span>
                    </div>
                  }
                  else if (novel.PublishStatus == PublishStatus.Rejected)
                  {
                    <div class="alert alert-danger py-1 px-2 mb-0" style="font-size:12px;">
                      <div class="d-flex align-items-center gap-2 mb-1">
                        <i class="fas fa-@(novel.LastReviewAction == ReviewAction.RequestRevision
                            ? "edit" : "times-circle")"></i>
                        <strong>
                          @(novel.LastReviewAction == ReviewAction.RequestRevision
                              ? "Revision Requested" : "Rejected")
                        </strong>
                      </div>
                      @if (!string.IsNullOrEmpty(novel.LastReviewNote))
                      {
                        <div class="mb-1">@novel.LastReviewNote</div>
                      }
                      @if (novel.LastReviewAction == ReviewAction.RequestRevision)
                      {
                        <a href="/novels/edit/@novel.Id" class="btn btn-xs btn-danger">
                          <i class="fas fa-edit me-1"></i> Edit & Resubmit
                        </a>
                      }
                    </div>
                  }

                </div>
              </div>
            </div>
          </div>
        }
      </div>

      <!-- Pagination -->
      @if (Model.TotalPages > 1)
      {
        <nav class="mt-4">
          <ul class="pagination justify-content-center">
            @for (int p = 1; p <= Model.TotalPages; p++)
            {
              <li class="page-item @(p == Model.PageNumber ? "active" : "")">
                <a class="page-link"
                   href="?search=@Model.Search&status=@Model.StatusFilter&page-number=@p">
                  @p
                </a>
              </li>
            }
          </ul>
        </nav>
      }
    }
  </div>
</div>

<!-- Delete confirm modal -->
<div class="modal fade" id="modalDelete" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <form method="post" asp-page-handler="Delete">
        <input type="hidden" name="novelId" id="del_novelId" />
        <div class="modal-header border-0 pb-0">
          <h6 class="modal-title text-danger">
            <i class="fas fa-exclamation-triangle me-2"></i>Delete Novel
          </h6>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body pt-2">
          <p class="small mb-1">You are about to delete:</p>
          <p class="fw-semibold" id="del_novelTitle"></p>
          <p class="text-danger small mb-0">
            <i class="fas fa-warning me-1"></i>
            All volumes and chapters will be permanently deleted.
          </p>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-sm btn-outline-secondary"
                  data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-sm btn-danger">Delete</button>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
.novel-row { transition: box-shadow .15s; }
.novel-row:hover { box-shadow: 0 4px 16px rgba(0,0,0,.1) !important; }
.btn-xs { padding: 1px 6px; font-size: 11px; line-height: 1.5; border-radius: 3px; }
</style>

@section Scripts {
<script>
function confirmDelete(id, title) {
    document.getElementById('del_novelId').value         = id;
    document.getElementById('del_novelTitle').textContent = title;
    new bootstrap.Modal(document.getElementById('modalDelete')).show();
}
</script>
}