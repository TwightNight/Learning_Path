@page "/login"
@model NovelManangment.Pages.LoginModel
@{
    Layout = null; // Không dùng AdminLTE layout cho trang login
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — NovelX Studio</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        body { background: #e8eef5; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-card { background: #f8f9fb; border: 1px solid #d0d8e8; border-radius: 16px; padding: 2.5rem; width: 100%; max-width: 420px; box-shadow: 0 20px 60px rgba(0,0,0,.08); }
        .login-card h1 { font-size: 1.6rem; font-weight: 700; color: #1a1a2e; }
        .login-card .subtitle { color: #666; font-size: .9rem; }
        .form-control { background: #f0f2f8; border: 1px solid #d0d8e8; color: #1a1a2e; border-radius: 8px; }
        .form-control:focus { background: #f0f2f8; border-color: #4f8ef7; color: #1a1a2e; box-shadow: 0 0 0 3px rgba(79,142,247,.15); }
        .form-label { color: #555; font-size: .85rem; }
        .btn-login { background: linear-gradient(135deg, #4f8ef7, #7c4fff); border: none; border-radius: 8px; font-weight: 600; padding: .65rem; }
        .btn-login:hover { opacity: .9; }
        .alert-danger { background: rgba(220,53,69,.1); border: 1px solid rgba(220,53,69,.25); color: #d63545; border-radius: 8px; font-size: .875rem; }
        .register-link { color: #4f8ef7; }
        .input-group-text { background: #f0f2f8; border: 1px solid #d0d8e8; color: #555; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center mb-4">
            <h1>NovelX Studio</h1>
            <p class="subtitle">Sign in to your account</p>
        </div>

        @if (Model.ErrorMessage is not null)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle me-2"></i>@Model.ErrorMessage
            </div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.UserName" class="form-label">Username</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                    <input asp-for="Input.UserName" class="form-control" placeholder="Enter username..." autofocus />
                </div>
                <span asp-validation-for="Input.UserName" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Input.Password" class="form-label">Password</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    <input asp-for="Input.Password" type="password" class="form-control" placeholder="Enter password..." />
                    <button class="input-group-text" type="button" onclick="togglePwd()" style="cursor:pointer;">
                        <i class="fas fa-eye" id="eyeIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-login btn-primary w-100">
                <i class="fas fa-sign-in-alt me-2"></i>Sign In
            </button>
        </form>

        <p class="text-center mt-3 mb-0" style="color:#666;font-size:.875rem;">
            Don't have an account?
            <a href="/register" class="register-link">Register</a>
        </p>
    </div>

    <script>
        function togglePwd() {
            const input = document.getElementById('Input_Password');
            const icon  = document.getElementById('eyeIcon');
            const isHidden = input.type === 'password';
            input.type      = isHidden ? 'text' : 'password';
            icon.className  = isHidden ? 'fas fa-eye-slash' : 'fas fa-eye';
        }
    </script>
</body>
</html>