@page "/privacy"
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="app-content">
    <div class="container-fluid">

        ```
        <!-- Page Header -->
        <div class="row mb-4">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-shield-alt text-primary"></i>
                    Privacy Policy
                </h1>
            </div>
        </div>

        <!-- Privacy Card -->
        <div class="card card-primary card-outline shadow-sm">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-user-secret"></i>
                    Your Privacy Matters
                </h3>
            </div>

            <div class="card-body">

                <p>
                    At <strong>NovelX Studio</strong>, we respect your privacy and
                    are committed to protecting your personal information.
                </p>

                <hr />

                <h5>
                    <i class="fas fa-database text-info"></i>
                    Information We Collect
                </h5>

                <ul>
                    <li>Account information such as username, email, and display name.</li>
                    <li>Novel and content data created within the platform.</li>
                    <li>Authentication and session information required for security.</li>
                    <li>System logs used for monitoring and troubleshooting.</li>
                </ul>

                <hr />

                <h5>
                    <i class="fas fa-lock text-success"></i>
                    How We Protect Your Data
                </h5>

                <p>
                    We implement industry-standard security measures to safeguard
                    your information against unauthorized access, disclosure,
                    alteration, or destruction.
                </p>

                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i>
                    Passwords and authentication data are handled securely and are
                    never shared with third parties.
                </div>

                <hr />

                <h5>
                    <i class="fas fa-share-alt text-warning"></i>
                    Data Sharing
                </h5>

                <p>
                    NovelX Studio does not sell or rent personal information.
                    Information may only be shared when required by law or for
                    platform security purposes.
                </p>

                <hr />

                <h5>
                    <i class="fas fa-cookie-bite text-danger"></i>
                    Cookies & Sessions
                </h5>

                <p>
                    We use authentication cookies and session data to maintain
                    user login status and improve the platform experience.
                </p>

                <hr />

                <h5>
                    <i class="fas fa-envelope text-primary"></i>
                    Contact Us
                </h5>

                <p>
                    If you have any questions regarding this Privacy Policy,
                    please contact the NovelX Studio administration team.
                </p>

            </div>

            <div class="card-footer text-muted">
                Last Updated: June 2026
            </div>
        </div>

    </div>
    ```

</div>
