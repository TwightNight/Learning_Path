@page "/register"
@model NovelManangment.Pages.RegisterModel
@{
    Layout = null;
    ViewData["Title"] = "Register";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register — NovelX Studio</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        body { background: #e8eef5; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem 0; }
        .register-card { background: #f8f9fb; border: 1px solid #d0d8e8; border-radius: 16px; padding: 2.5rem; width: 100%; max-width: 460px; box-shadow: 0 20px 60px rgba(0,0,0,.08); }
        .register-card h1 { font-size: 1.6rem; font-weight: 700; color: #1a1a2e; }
        .form-control { background: #f0f2f8; border: 1px solid #d0d8e8; color: #1a1a2e; border-radius: 8px; }
        .form-control:focus { background: #f0f2f8; border-color: #4f8ef7; color: #1a1a2e; box-shadow: 0 0 0 3px rgba(79,142,247,.15); }
        .form-label { color: #555; font-size: .85rem; }
        .btn-register { background: linear-gradient(135deg, #4f8ef7, #7c4fff); border: none; border-radius: 8px; font-weight: 600; padding: .65rem; }
        .alert-danger { background: rgba(220,53,69,.1); border: 1px solid rgba(220,53,69,.25); color: #d63545; border-radius: 8px; font-size: .875rem; }
        .input-group-text { background: #f0f2f8; border: 1px solid #d0d8e8; color: #555; }
        .login-link { color: #4f8ef7; }
        .password-strength { height: 4px; border-radius: 2px; transition: width .3s, background .3s; }
    </style>
</head>
<body>
    <div class="register-card">
        <div class="text-center mb-4">
            <h1>NovelX Studio</h1>
            <p style="color:#888;font-size:.9rem;">Create your publisher account</p>
        </div>

        @if (Model.ErrorMessage is not null)
        {
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle me-2"></i>@Model.ErrorMessage
            </div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.UserName" class="form-label">Username</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-at"></i></span>
                    <input asp-for="Input.UserName" class="form-control" placeholder="letters, numbers, underscore..." />
                </div>
                <span asp-validation-for="Input.UserName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                    <input asp-for="Input.Email" class="form-control" placeholder="you@example.com" />
                </div>
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.DisplayName" class="form-label">Display Name</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-id-card"></i></span>
                    <input asp-for="Input.DisplayName" class="form-control" placeholder="Your public name..." />
                </div>
                <span asp-validation-for="Input.DisplayName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">Password</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    <input asp-for="Input.Password" type="password" class="form-control"
                           placeholder="At least 6 characters..."
                           oninput="checkStrength(this.value)" />
                    <button class="input-group-text" type="button" onclick="togglePwd('Input_Password','eye1')" style="cursor:pointer;">
                        <i class="fas fa-eye" id="eye1"></i>
                    </button>
                </div>
                <div class="mt-1 bg-secondary bg-opacity-25 rounded" style="height:4px;">
                    <div id="strengthBar" class="password-strength" style="width:0;background:#dc3545;"></div>
                </div>
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Input.ConfirmPassword" class="form-label">Confirm Password</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Repeat password..." />
                    <button class="input-group-text" type="button" onclick="togglePwd('Input_ConfirmPassword','eye2')" style="cursor:pointer;">
                        <i class="fas fa-eye" id="eye2"></i>
                    </button>
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-register btn-primary w-100">
                <i class="fas fa-user-plus me-2"></i>Create Account
            </button>
        </form>

        <p class="text-center mt-3 mb-0" style="color:#666;font-size:.875rem;">
            Already have an account?
            <a href="/login" class="login-link">Sign in</a>
        </p>
    </div>

    <script>
        function togglePwd(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon  = document.getElementById(iconId);
            const isHidden = input.type === 'password';
            input.type     = isHidden ? 'text' : 'password';
            icon.className = isHidden ? 'fas fa-eye-slash' : 'fas fa-eye';
        }

        function checkStrength(val) {
            const bar = document.getElementById('strengthBar');
            let score = 0;
            if (val.length >= 6)  score++;
            if (val.length >= 10) score++;
            if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;

            const map = ['0%', '25%', '50%', '75%', '100%'];
            const colors = ['#dc3545','#fd7e14','#ffc107','#20c997','#198754'];
            bar.style.width      = map[score];
            bar.style.background = colors[score];
        }
    </script>
</body>
</html>