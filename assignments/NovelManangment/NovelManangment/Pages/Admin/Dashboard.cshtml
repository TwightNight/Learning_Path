@page "/admin/dashboard"
@model NovelManangment.Pages.Admin.DashboardModel
@using NovelManangment.Models
@{
    ViewData["Title"] = "Admin Dashboard";

    var statusMeta = new Dictionary<NovelStatus, (string label, string css)>
    {
        [NovelStatus.Ongoing] = ("Ongoing", "text-bg-success"),
        [NovelStatus.Completed] = ("Completed", "text-bg-primary"),
        [NovelStatus.Hiatus] = ("Hiatus", "text-bg-warning"),
        [NovelStatus.Dropped] = ("Dropped", "text-bg-danger"),
    };
    var typeMeta = new Dictionary<NovelType, (string label, string css)>
    {
        [NovelType.Original] = ("Original", "text-bg-info"),
        [NovelType.Raw] = ("Raw", "text-bg-secondary"),
        [NovelType.MachineTranslated] = ("Machine Translated", "text-bg-warning"),
        [NovelType.HumanTranslated] = ("Human Translated", "text-bg-primary"),
        [NovelType.Parody] = ("Parody", "text-bg-dark"),
    };
    var roleMeta = new Dictionary<UserRole, (string label, string css)>
    {
        [UserRole.Member] = ("Member", "text-bg-secondary"),
        [UserRole.Publisher] = ("Publisher", "text-bg-info"),
        [UserRole.Admin] = ("Admin", "text-bg-danger"),
    };

    int maxWeekly = Model.WeeklyChapters.Any()
        ? Math.Max(Model.WeeklyChapters.Max(d => d.Count), 1) : 1;
    long maxViews = Model.TopNovels.Any()
        ? Math.Max(Model.TopNovels.Max(n => n.TotalViews), 1) : 1;
}

<div class="app-content-header">
    <div class="container-fluid">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h3 class="mb-0">
                    <i class="fas fa-shield-alt text-danger me-2"></i>Admin Dashboard
                </h3>
                <small class="text-muted">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</small>
            </div>
            <div class="d-flex gap-2">
                <a href="/users" class="btn btn-sm btn-outline-primary">
                    <i class="fas fa-users me-1"></i> Manage Users
                </a>
                <a href="/admin/novels" class="btn btn-sm btn-outline-success">
                    <i class="fas fa-book me-1"></i> Manage Novels
                </a>
            </div>
        </div>
    </div>
</div>

<div class="app-content">
    <div class="container-fluid">

        <!-- ══ ROW 1: Overview stats ══ -->
        <div class="row g-3 mb-4">
            @{
                var stats = new[]
                {
            (icon:"fa-book",        color:"primary", label:"Total Novels",
             val:Model.TotalNovels.ToString(),
             sub:$"+{Model.NewNovelsThisMonth} this month"),
            (icon:"fa-list-ol",     color:"success", label:"Total Chapters",
             val:Model.TotalChapters.ToString("N0"),
             sub:$"+{Model.NewChaptersThisMonth} this month"),
            (icon:"fa-eye",         color:"warning", label:"Total Views",
             val:FormatNum(Model.TotalViews),
             sub:"all time"),
            (icon:"fa-users",       color:"info",    label:"Total Users",
             val:Model.TotalUsers.ToString("N0"),
             sub:$"+{Model.NewUsersThisMonth} this month"),
            (icon:"fa-user-edit",   color:"danger",  label:"Publishers",
             val:Model.TotalPublishers.ToString(),
             sub:"active"),
            (icon:"fa-book-open",   color:"secondary",label:"Volumes",
             val:Model.TotalVolumes.ToString("N0"),
             sub:"total"),
            (icon:"fa-tags",        color:"success", label:"Genres",
             val:Model.TotalGenres.ToString(),
             sub:"categories"),
        };
            }
            @foreach (var s in stats)
            {
                <div class="col-6 col-md-4 col-xl-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body d-flex align-items-center gap-3 py-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width:48px;height:48px;background:var(--bs-@(s.color)-bg-subtle,#f0f0f0);">
                                <i class="fas @s.icon text-@s.color" style="font-size:18px;"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="fw-bold fs-5 lh-1">@s.val</div>
                                <div class="text-muted small">@s.label</div>
                                <div class="text-success" style="font-size:11px;">@s.sub</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- ══ ROW 2: Charts row ══ -->
        <div class="row g-3 mb-4">

            <!-- Weekly chapters bar chart -->
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom py-2">
                        <h6 class="mb-0 fw-semibold">
                            <i class="fas fa-chart-bar me-1 text-primary"></i>
                            Chapters Added (Last 7 Days)
                        </h6>
                    </div>
                    <div class="card-body px-3 pb-3 pt-2">
                        <div class="d-flex align-items-end gap-2" style="height:140px;">
                            @foreach (var day in Model.WeeklyChapters)
                            {
                                var pct = maxWeekly > 0 ? (int)((double)day.Count / maxWeekly * 100) : 0;
                                <div class="d-flex flex-column align-items-center flex-grow-1 h-100
                                    justify-content-end gap-1">
                                    <span style="font-size:10px;color:#888;">@day.Count</span>
                                    <div class="rounded-top bg-primary w-100"
                                         style="height:@(Math.Max(pct, 2))%;min-height:3px;transition:height .3s;"></div>
                                    <span style="font-size:9px;color:#aaa;white-space:nowrap;">
                                        @day.Label.Split(' ')[0]<br />@day.Label.Split(' ')[1]
                                    </span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Novel by status donut -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom py-2">
                        <h6 class="mb-0 fw-semibold">
                            <i class="fas fa-chart-pie me-1 text-success"></i>
                            Novels by Status
                        </h6>
                    </div>
                    <div class="card-body d-flex align-items-center gap-4">
                        @* <canvas id="statusChart" width="120" height="120"></canvas> *@
                        <div style="width:210px;height:210px;flex-shrink:0;">
                            <canvas id="statusChart"></canvas>
                        </div>
                        <div class="d-flex flex-column gap-2 flex-grow-1" style="font-size:13px;">
                            @foreach (var s in Enum.GetValues<NovelStatus>())
                            {
                                var count = Model.NovelsByStatus.GetValueOrDefault(s, 0);
                                <div class="d-flex align-items-center">
                                    <span>
                                        <span class="badge @statusMeta[s].css me-1" style="font-size:10px;">●</span>
                                        @statusMeta[s].label
                                    </span>
                                    <strong class="ms-2">@count</strong>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Novel by type -->
            <div class="col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white border-bottom py-2">
                        <h6 class="mb-0 fw-semibold">
                            <i class="fas fa-layer-group me-1 text-warning"></i>
                            Novels by Type
                        </h6>
                    </div>
                    <div class="card-body d-flex flex-column justify-content-center gap-2"
                         style="font-size:13px;">
                        @foreach (var t in Enum.GetValues<NovelType>())
                        {
                            var count = Model.NovelsByType.GetValueOrDefault(t, 0);
                            var pct = Model.TotalNovels > 0
                                  ? (int)((double)count / Model.TotalNovels * 100) : 0;
                            <div>
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="badge @typeMeta[t].css" style="font-size:10px;">
                                        @typeMeta[t].label
                                    </span>
                                    <span class="text-muted">@count (@pct%)</span>
                                </div>
                                <div class="progress" style="height:5px;">
                                    <div class="progress-bar" style="width:@pct%"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- ══ ROW 3: Tables ══ -->
        <div class="row g-3 mb-4">

            <!-- Top novels by views -->
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom d-flex align-items-center
                        justify-content-between py-2">
                        <h6 class="mb-0 fw-semibold">
                            <i class="fas fa-fire me-1 text-danger"></i> Top Novels by Views
                        </h6>
                    </div>
                    <div class="card-body p-0">
                        @foreach (var (novel, idx) in Model.TopNovels.Select((n, i) => (n, i)))
                        {
                            <div class="d-flex align-items-center gap-3 px-3 py-2
                                @(idx < Model.TopNovels.Count - 1 ? "border-bottom" : "")">
                                <span class="fw-bold text-muted" style="width:20px;font-size:15px;">
                                    @(idx + 1)
                                </span>
                                @if (!string.IsNullOrEmpty(novel.CoverUrl))
                                {
                                    <img src="@novel.CoverUrl" alt=""
                                         style="width:32px;height:45px;object-fit:cover;
                                    border-radius:3px;flex-shrink:0;" />
                                }
                                else
                                {
                                    <div style="width:32px;height:45px;background:#e9ecef;border-radius:3px;
                                        display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                        <i class="fas fa-book text-muted" style="font-size:11px;"></i>
                                    </div>
                                }
                                <div class="flex-grow-1 min-w-0">
                                    <div class="fw-semibold text-truncate" style="font-size:13px;">
                                        <a href="/novels/@novel.Slug" target="_blank"
                                           class="text-decoration-none text-reset">@novel.Title</a>
                                    </div>
                                    <div style="font-size:11px;color:#aaa;">
                                        @novel.TotalChapters ch ·
                                        <span class="badge @statusMeta[novel.Status].css"
                                              style="font-size:9px;">@statusMeta[novel.Status].label</span>
                                    </div>
                                </div>
                                <div class="text-end flex-shrink-0">
                                    <div class="fw-semibold" style="font-size:13px;">
                                        @FormatNum(novel.TotalViews)
                                    </div>
                                    <div class="progress mt-1" style="height:3px;width:60px;">
                                        <div class="progress-bar bg-danger"
                                             style="width:@((int)((double)novel.TotalViews / maxViews * 100))%"></div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Top publishers -->
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom d-flex align-items-center
                        justify-content-between py-2">
                        <h6 class="mb-0 fw-semibold">
                            <i class="fas fa-trophy me-1 text-warning"></i> Top Publishers
                        </h6>
                    </div>
                    <div class="card-body p-0">
                        @foreach (var (pub, idx) in Model.TopPublishers.Select((p, i) => (p, i)))
                        {
                            <div class="d-flex align-items-center gap-3 px-3 py-2
                                @(idx < Model.TopPublishers.Count - 1 ? "border-bottom" : "")">
                                <span class="fw-bold text-muted" style="width:20px;font-size:15px;">@(idx + 1)</span>
                                @if (!string.IsNullOrEmpty(pub.AvatarUrl))
                                {
                                    <img src="@pub.AvatarUrl" alt=""
                                         style="width:36px;height:36px;border-radius:50%;
                                    object-fit:cover;flex-shrink:0;" />
                                }
                                else
                                {
                                    <div style="width:36px;height:36px;border-radius:50%;
                                        background:linear-gradient(135deg,#667eea,#764ba2);
                                        display:flex;align-items:center;justify-content:center;
                                        flex-shrink:0;color:#fff;font-weight:700;font-size:14px;">
                                        @pub.DisplayName[0]
                                    </div>
                                }
                                <div class="flex-grow-1 min-w-0">
                                    <div class="fw-semibold" style="font-size:13px;">@pub.DisplayName</div>
                                    <div style="font-size:11px;color:#aaa;">
                                        @pub.TotalNovels novels · @pub.TotalChapters ch
                                    </div>
                                </div>
                                <div class="text-end text-muted" style="font-size:12px;flex-shrink:0;">
                                    <i class="fas fa-eye me-1"></i>@FormatNum(pub.TotalViews)
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- ══ ROW 4: Recent activity ══ -->
        <div class="row g-3">

            <!-- Recent novels -->
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom d-flex align-items-center
                        justify-content-between py-2">
                        <h6 class="mb-0 fw-semibold">
                            <i class="fas fa-clock me-1 text-info"></i> Recently Added Novels
                        </h6>
                        <a href="/novels" class="btn btn-xs btn-outline-secondary"
                           style="font-size:11px;padding:2px 8px;">View all</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover table-sm mb-0" style="font-size:12px;">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Cover</th>
                                    <th>Title</th>
                                    <th>Publisher</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                    <th class="pe-3">Added</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var n in Model.RecentNovels)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            @if (!string.IsNullOrEmpty(n.CoverUrl))
                                            {
                                                <img src="@n.CoverUrl" style="width:24px;height:34px;
                                                object-fit:cover;border-radius:2px;" />
                                            }
                                            else
                                            {
                                                <div style="width:24px;height:34px;background:#e9ecef;
                                                    border-radius:2px;display:flex;align-items:center;
                                                    justify-content:center;">
                                                    <i class="fas fa-book text-muted" style="font-size:9px;"></i>
                                                </div>
                                            }
                                        </td>
                                        <td class="fw-medium">
                                            <a href="/novels/@n.Slug" target="_blank"
                                                   class="text-decoration-none text-reset">
                                                @(n.Title.Length > 30 ? n.Title[..30] + "…" : n.Title)
                                            </a>
                                        </td>
                                        <td class="text-muted">@n.PublisherName</td>
                                        <td>
                                            <span class="badge @typeMeta[n.Type].css" style="font-size:9px;">
                                                @typeMeta[n.Type].label
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge @statusMeta[n.Status].css" style="font-size:9px;">
                                                @statusMeta[n.Status].label
                                            </span>
                                        </td>
                                        <td class="text-muted pe-3">@Model.GetTimeAgo(n.CreatedAt)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Recent users -->
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom d-flex align-items-center
                        justify-content-between py-2">
                        <h6 class="mb-0 fw-semibold">
                            <i class="fas fa-user-plus me-1 text-success"></i> New Users
                        </h6>
                        <a href="/users" class="btn btn-xs btn-outline-secondary"
                           style="font-size:11px;padding:2px 8px;">View all</a>
                    </div>
                    <div class="card-body p-0">
                        @foreach (var (user, idx) in Model.RecentUsers.Select((u, i) => (u, i)))
                        {
                            <div class="d-flex align-items-center gap-2 px-3 py-2
                                @(idx < Model.RecentUsers.Count - 1 ? "border-bottom" : "")">
                                @if (!string.IsNullOrEmpty(user.AvatarUrl))
                                {
                                    <img src="@user.AvatarUrl" style="width:32px;height:32px;border-radius:50%;
                                    object-fit:cover;flex-shrink:0;" />
                                }
                                else
                                {
                                    <div style="width:32px;height:32px;border-radius:50%;flex-shrink:0;
                                        background:linear-gradient(135deg,#f093fb,#f5576c);
                                        display:flex;align-items:center;justify-content:center;
                                        color:#fff;font-weight:700;font-size:13px;">
                                        @user.DisplayName[0]
                                    </div>
                                }
                                <div class="flex-grow-1 min-w-0">
                                    <div class="fw-semibold text-truncate" style="font-size:12px;">
                                        @user.DisplayName
                                    </div>
                                    <div class="text-muted text-truncate" style="font-size:11px;">
                                        @user.Email
                                    </div>
                                </div>
                                <div class="d-flex flex-column align-items-end gap-1 flex-shrink-0">
                                    <span class="badge @roleMeta[user.Role].css" style="font-size:9px;">
                                        @roleMeta[user.Role].label
                                    </span>
                                    <span class="text-muted" style="font-size:10px;">
                                        @Model.GetTimeAgo(user.CreatedAt)
                                    </span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@functions {
    string FormatNum(long n)
    {
        if (n >= 1_000_000) return $"{n / 1_000_000.0:F1}M";
        if (n >= 1_000) return $"{n / 1_000.0:F1}K";
        return n.ToString();
    }
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // Donut chart — novel by status
        const ctx = document.getElementById('statusChart').getContext('2d');
        new Chart(ctx, {
        type: 'doughnut',
        data: {
        labels: ['Ongoing', 'Completed', 'Hiatus', 'Dropped'],
        datasets: [{
        data: [
        @Model.NovelsByStatus.GetValueOrDefault(NovelStatus.Ongoing, 0),
        @Model.NovelsByStatus.GetValueOrDefault(NovelStatus.Completed, 0),
        @Model.NovelsByStatus.GetValueOrDefault(NovelStatus.Hiatus, 0),
        @Model.NovelsByStatus.GetValueOrDefault(NovelStatus.Dropped, 0)
        ],
        backgroundColor: ['#198754','#0d6efd','#ffc107','#dc3545'],
        borderWidth: 2,
        borderColor: '#fff'
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '70%',
        plugins: { legend: { display: false }, tooltip: { enabled: true } },
        animation: { animateScale: true }
        }
        });
    </script>
}