@page
@model ContosoUniversity.Pages.Students.IndexModel

@{
    ViewData["Title"] = "Students";
}

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="mb-3 text-primary"><i class="fas fa-filter"></i> Advanced Filter</h5>
        
        <!-- Advanced Filter Form -->
        <form asp-page="./Index" method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label text-muted mb-1">Search by Name</label>
                    <input type="text"
                           name="SearchString"
                           value="@Model.CurrentFilter"
                           class="form-control"
                           placeholder="Enter First or Last Name..." />
                </div>

                <div class="col-md-3">
                    <label class="form-label text-muted mb-1">From Date</label>
                    <input type="date"
                           name="fromDate"
                           value="@Model.CurrentFromDate?.ToString("yyyy-MM-dd")"
                           class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label text-muted mb-1">To Date</label>
                    <input type="date"
                           name="toDate"
                           value="@Model.CurrentToDate?.ToString("yyyy-MM-dd")"
                           class="form-control" />
                </div>

                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search"></i> Search
                    </button>
                </div>
            </div>
            
            <div class="row mt-2">
                <div class="col-12">
                    <a asp-page="./Index" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-sync-alt"></i> Clear Filters
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title m-0">Students Management</h3>
        <div class="ms-auto">
            <a asp-page="Create" class="btn btn-success btn-sm">
                <i class="fas fa-plus"></i> Create New
            </a>
        </div>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover table-striped m-0">
            <thead class="table-light">
                <tr>
                    <th>
                        <!-- Sorting link for Last Name -->
                        <a asp-page="./Index" asp-route-sortOrder="@Model.NameSort"
                               asp-route-searchString="@Model.CurrentFilter"
                               asp-route-fromDate="@Model.CurrentFromDate?.ToString("yyyy-MM-dd")"
                               asp-route-toDate="@Model.CurrentToDate?.ToString("yyyy-MM-dd")" class="text-dark text-decoration-none">
                            Last Name <i class="fas fa-sort"></i>
                        </a>
                    </th>
                    <th>First Name</th>
                    <th>
                        <!-- Sorting link for Enrollment Date -->
                        <a asp-page="./Index" asp-route-sortOrder="@Model.DateSort"
                               asp-route-searchString="@Model.CurrentFilter"
                               asp-route-fromDate="@Model.CurrentFromDate?.ToString("yyyy-MM-dd")"
                               asp-route-toDate="@Model.CurrentToDate?.ToString("yyyy-MM-dd")" class="text-dark text-decoration-none">
                            Enrollment Date <i class="fas fa-sort"></i>
                        </a>
                    </th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Students.Any())
                {
                    @foreach (var item in Model.Students)
                    {
                        <tr>
                            <td class="align-middle">@item.LastName</td>
                            <td class="align-middle">@item.FirstMidName</td>
                            <td class="align-middle">@item.EnrollmentDate.ToShortDateString()</td>
                            <td class="text-center align-middle">
                                <a asp-page="./Edit" asp-route-id="@item.ID" class="btn btn-warning btn-sm" title="Edit">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-page="./Details" asp-route-id="@item.ID" class="btn btn-info btn-sm text-white" title="Details">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-page="./Delete" asp-route-id="@item.ID" class="btn btn-danger btn-sm" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">No records found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Pagination -->
<div class="d-flex justify-content-center mt-4">
    <ul class="pagination pagination-sm m-0">
        @if (Model.CurrentPage > 1)
        {
            <li class="page-item">
                <a class="page-link"
                       asp-page="./Index"
                       asp-route-pageIndex="@(Model.CurrentPage - 1)"
                       asp-route-searchString="@Model.CurrentFilter"
                       asp-route-fromDate="@Model.CurrentFromDate?.ToString("yyyy-MM-dd")"
                       asp-route-toDate="@Model.CurrentToDate?.ToString("yyyy-MM-dd")">
                    &laquo; Previous
                </a>
            </li>
        }
        else
        {
            <li class="page-item disabled"><span class="page-link">&laquo; Previous</span></li>
        }

        <li class="page-item active">
            <span class="page-link">@Model.CurrentPage / @(Model.TotalPages == 0 ? 1 : Model.TotalPages)</span>
        </li>

        @if (Model.CurrentPage < Model.TotalPages)
        {
            <li class="page-item">
                <a class="page-link"
                       asp-page="./Index"
                       asp-route-pageIndex="@(Model.CurrentPage + 1)"
                       asp-route-searchString="@Model.CurrentFilter"
                       asp-route-fromDate="@Model.CurrentFromDate?.ToString("yyyy-MM-dd")"
                       asp-route-toDate="@Model.CurrentToDate?.ToString("yyyy-MM-dd")">
                    Next &raquo;
                </a>
            </li>
        }
        else
        {
            <li class="page-item disabled"><span class="page-link">Next &raquo;</span></li>
        }
    </ul>
</div>