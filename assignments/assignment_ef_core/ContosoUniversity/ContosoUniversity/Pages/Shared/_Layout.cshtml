<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Contoso University</title>

    @* <!-- Font Awesome CDN -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Bootstrap 5 -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /> *@

    <!-- AdminLTE -->
    <link rel="stylesheet"
          href="~/admin-lte/dist/css/adminlte.min.css" />

    <style>
            body {
                background-color: #f4f6f9;
            }

            .brand-link {
                text-align: center;
                font-size: 1.2rem;
                font-weight: 600;
            }

            .content-wrapper {
                background: #f4f6f9;
            }

            .card {
                border: none;
                border-radius: 12px;
            }

            .nav-sidebar .nav-link {
                border-radius: 8px;
                margin-bottom: 4px;
            }
    </style>
</head>

<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">

    <div class="app-wrapper">

        <!-- Navbar -->
        <nav class="app-header navbar navbar-expand bg-white shadow-sm">
            <div class="container-fluid">

                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" data-lte-toggle="sidebar" href="#">
                            <i class="fas fa-bars"></i>
                        </a>
                    </li>
                </ul>

                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#">
                            <i class="fas fa-user-circle"></i>
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Sidebar -->
        <aside class="app-sidebar bg-dark shadow" data-bs-theme="dark">

            <div class="sidebar-brand">
                <a asp-page="/Index" class="brand-link text-white text-decoration-none">
                    Contoso University
                </a>
            </div>

            <div class="sidebar-wrapper">
                <nav class="mt-2">

                    <ul class="nav sidebar-menu flex-column"
                        data-lte-toggle="treeview"
                        role="menu">

                        <li class="nav-item">
                            <a asp-page="/Index" class="nav-link active">
                                <i class="nav-icon fas fa-home"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-page="/Students/Index" class="nav-link">
                                <i class="nav-icon fas fa-user-graduate"></i>
                                <p>Students</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-page="/Courses/Index" class="nav-link">
                                <i class="nav-icon fas fa-book"></i>
                                <p>Courses</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-page="/Instructors/Index" class="nav-link">
                                <i class="nav-icon fas fa-chalkboard-teacher"></i>
                                <p>Instructors</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-page="/About" class="nav-link">
                                <i class="nav-icon fas fa-building"></i>
                                <p>About</p>
                            </a>
                        </li>

                    </ul>

                </nav>
            </div>
        </aside>

        <!-- Main -->
        <main class="app-main">

            <!-- Content Header -->
            <div class="app-content-header">
                <div class="container-fluid">
                    <h3 class="mb-3">@ViewData["Title"]</h3>
                </div>
            </div>

            <!-- Content -->
            <div class="app-content">
                <div class="container-fluid">

                    <div class="card shadow-sm">
                        <div class="card-body">
                            @RenderBody()
                        </div>
                    </div>

                </div>
            </div>
        </main>

        <!-- Footer -->
        <footer class="app-footer text-center">
            <strong>Copyright &copy; 2026</strong>
            Contoso University
        </footer>
    </div>

    @* <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script> *@

    <!-- AdminLTE -->
    <script src="~/admin-lte/dist/js/adminlte.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>