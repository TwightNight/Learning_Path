@page
@model ContosoUniversity.Pages.Departments.IndexModel

@{
    ViewData["Title"] = "Departments";
}

<div class="card shadow-sm mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title m-0">Departments Management</h3>
        <div class="ms-auto">
            <a asp-page="Create" class="btn btn-success btn-sm">
                <i class="fas fa-plus"></i> Create New
            </a>
        </div>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover table-striped m-0">
            <thead class="table-light">
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.Department[0].Name)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Department[0].Budget)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Department[0].StartDate)
                    </th>
                    <th>
                        Administrator
                    </th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Department != null && Model.Department.Any())
                {
                    @foreach (var item in Model.Department)
                    {
                        <tr>
                            <td class="align-middle">
                                @Html.DisplayFor(modelItem => item.Name)
                            </td>
                            <td class="align-middle fw-bold text-success">
                                @Html.DisplayFor(modelItem => item.Budget)
                            </td>
                            <td class="align-middle">
                                @Html.DisplayFor(modelItem => item.StartDate)
                            </td>
                            <td class="align-middle">
                                
                                @Html.DisplayFor(modelItem => item.Administrator.FullName)
                            </td>
                            <td class="text-center align-middle">
                                <a asp-page="./Edit" asp-route-id="@item.DepartmentID" class="btn btn-warning btn-sm" title="Edit">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-page="./Details" asp-route-id="@item.DepartmentID" class="btn btn-info btn-sm text-white" title="Details">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-page="./Delete" asp-route-id="@item.DepartmentID" class="btn btn-danger btn-sm" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No records found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>