@page
@model ContosoUniversity.Pages.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Log in";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Contoso University | Log in</title>

    <!-- Font Awesome CDN cho các icon (Hình ổ khóa, user) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- AdminLTE CSS (Lấy từ thư mục wwwroot của bạn) -->
    <link rel="stylesheet" href="~/admin-lte/dist/css/adminlte.min.css" />

    <!-- Style bổ sung để căn giữa form đăng nhập ra giữa màn hình -->
    <style>
            .login-page {
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
            }

            .login-box {
                width: 100%;
                max-width: 400px;
            }
    </style>
</head>
<body class="login-page bg-light">
    <div class="login-box">
        <div class="login-logo text-center mb-3">
            <a href="#" class="text-decoration-none text-dark fs-2"><b>Contoso</b> University</a>
        </div>
        
        <div class="card card-outline card-primary shadow-sm border-top border-primary border-3">
            <div class="card-body login-card-body p-4">
                <p class="login-box-msg text-center text-muted mb-4">Sign in to start your session</p>

                @if (!ModelState.IsValid)
                {
                    <div class="alert alert-danger" role="alert">
                        Invalid username or password.
                    </div>
                }

                <form method="post">
                    <div class="input-group mb-3">
                        <span class="input-group-text bg-white"><i class="fas fa-user text-muted"></i></span>
                        <input type="text" asp-for="Input.Username" class="form-control" placeholder="Username" required>
                    </div>
                    
                    <div class="input-group mb-4">
                        <span class="input-group-text bg-white"><i class="fas fa-lock text-muted"></i></span>
                        <input type="password" asp-for="Input.Password" class="form-control" placeholder="Password" required>
                    </div>
                    
                    <div class="row">
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary w-100 fw-bold">
                                <i class="fas fa-sign-in-alt me-1"></i> Sign In
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>